# Configurações de E-mail
# -----------------------

# OPÇÃO 1: Mailtrap (Mais acessível para desenvolvedores)
# Crie uma conta gratuita em https://mailtrap.io e pegue as credenciais no "Inbox"
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=seu_usuario_do_mailtrap
EMAIL_PASSWORD=sua_senha_do_mailtrap
EMAIL_USE_TLS=true

# OPÇÃO 2: Gmail (Para enviar para caixas de entrada REAIS)
# Requer ativar "Verificação em duas etapas" e criar "Senha de App"
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=seu_email@gmail.com
# EMAIL_PASSWORD=sua_senha_de_app_16_digitos
# EMAIL_USE_TLS=true
